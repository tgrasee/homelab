# Copy this file to .env and set your values.
# .env is gitignored — never commit it.

# Shared secret between Woodpecker server and agent — set to any random string
WOODPECKER_AGENT_SECRET=changeme

# Gitea username to grant Woodpecker admin access
WOODPECKER_ADMIN=your-gitea-username

# Fill these in after creating an OAuth app in Gitea:
# Gitea → Settings → Applications → Manage OAuth2 Applications
# Redirect URI: http://192.168.1.52:8000/authorize
WOODPECKER_GITEA_CLIENT=
WOODPECKER_GITEA_SECRET=
